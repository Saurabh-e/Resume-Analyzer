# Production Environment Variables for Render
# Copy these to Render Dashboard → Environment Variables

# Server Configuration
NODE_ENV=production
PORT=10000

# MongoDB Configuration (MongoDB Atlas)
# Get this from: MongoDB Atlas → Database → Connect → Connect your application
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-resume-analyzer?retryWrites=true&w=majority

# JWT Configuration
# Generate a secure random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRE=7d

# Groq API Configuration
# Get this from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# CORS Configuration
# Set this to your deployed frontend URL (e.g., https://your-app.vercel.app)
CLIENT_URL=https://your-frontend-url.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
